# Backend Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL connection string
# Example: postgresql://username:password@localhost:5432/company_website
DATABASE_URL="postgresql://user:password@localhost:5432/company_website"

# Server port (optional, defaults to 5000)
PORT=5000

# CORS origin — the frontend URL that's allowed to call the API
CORS_ORIGIN="http://localhost:5500"

# JWT secret (for JSON Web Token authentication)
JWT_SECRET="your-secret-key-change-this"

# Session / Cookie secret
COOKIE_SECRET="your-cookie-secret-change-this"

