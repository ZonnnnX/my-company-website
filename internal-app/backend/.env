# ============================================
# Internal Application - Environment Variables
# ============================================
# Copy this file and rename to .env, then fill in your values.

# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- PostgreSQL Database ----
# The PostgreSQL port is 2112 on this machine (not the default 5432)
DB_HOST=localhost
DB_PORT=2112
DB_NAME=internal_app
DB_USER=postgres
DB_PASSWORD=postgres

# ---- JWT ----
JWT_SECRET=internal-app-jwt-secret-change-in-production-abc123
JWT_EXPIRES_IN=24h

