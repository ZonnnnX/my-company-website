<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — Internal App</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
    .gradient-bg { background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%); }
  </style>
</head>
<body class="gradient-bg min-h-screen">
  <nav class="bg-slate-800/60 backdrop-blur-sm border-b border-slate-700/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-emerald-400 flex items-center justify-center shadow-lg">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <div>
            <div class="text-white font-semibold text-lg">Dashboard</div>
            <div class="text-slate-400 text-xs">Welcome, <span class="text-blue-400"><%= user.role %></span></div>
        </div>
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-2 text-slate-300 text-sm">
            <span><%= user.username %></span>
            <span class="px-2 py-0.5 rounded-md bg-blue-500/15 text-blue-400 text-xs font-medium border border-blue-500/20"><%= user.role %></span>
          </div>
          <form action="/api/auth/logout" method="POST">
            <button class="flex items-center gap-1.5 px-3 py-2 rounded-lg bg-slate-700/50 border border-slate-600/50 text-slate-300 hover:text-white text-sm">
              Sign Out
            </button>
          </form>
        </div>
    </div>
  </nav>
  <main class="max-w-7xl mx-auto px-4 py-12 text-center">
    <div class="bg-slate-800/40 border border-slate-700/30 rounded-2xl p-12 max-w-lg mx-auto">
      <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-gradient-to-br from-blue-500 to-emerald-400 flex items-center justify-center shadow-xl">
        <span class="text-3xl font-bold text-white"><%= user.username.charAt(0).toUpperCase() %></span>
      </div>
      <h1 class="text-white text-2xl font-bold mb-2">Xin chào, <%= user.username %>!</h1>
      <p class="text-slate-400 mb-6">Bạn đã đăng nhập với vai trò <span class="text-blue-400 font-semibold"><%= user.role %></span></p>
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-slate-700/30 rounded-xl p-4">
          <div class="text-slate-400 text-xs">Email</div>
          <div class="text-white font-medium text-sm mt-1"><%= user.email %></div>
        <div class="bg-slate-700/30 rounded-xl p-4">
          <div class="text-slate-400 text-xs">Trạng thái</div>
          <div class="text-emerald-400 font-medium text-sm mt-1 flex items-center gap-1">
            <span class="w-2 h-2 rounded-full bg-emerald-400"></span> Approved
          </div>
        <div class="bg-slate-700/30 rounded-xl p-4">
          <div class="text-slate-400 text-xs">Vai trò</div>
          <div class="text-blue-400 font-medium text-sm mt-1"><%= user.role %></div>
        <div class="bg-slate-700/30 rounded-xl p-4">
          <div class="text-slate-400 text-xs">Ngày tham gia</div>
          <div class="text-white font-medium text-sm mt-1"><%= new Date(user.createdAt).toLocaleDateString('vi-VN') %></div>
      </div>
  </main>
</body>
</html>
